{
  "name": "@notebook-md/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "migrate:up": "node-pg-migrate up --migrations-dir migrations --migration-file-language sql",
    "migrate:down": "node-pg-migrate down --migrations-dir migrations --migration-file-language sql",
    "migrate:create": "node-pg-migrate create --migrations-dir migrations --migration-file-language sql",
    "seed": "tsx src/db/seed.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:cloud": "vitest run cloud- sharing feature-flag version-history",
    "test:auth": "vitest run auth sessions two-factor oauth dev-login",
    "test:notebooks": "vitest run notebooks path-validation",
    "test:providers": "vitest run github- onedrive- googledrive- circuit-breaker webhook",
    "test:misc": "vitest run admin contact encryption settings provider-revocation"
  },
  "dependencies": {
    "@notebook-md/shared": "*",
    "@types/archiver": "^7.0.0",
    "archiver": "^7.0.1",
    "bcryptjs": "^3.0.3",
    "compression": "^1.7.5",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^17.3.1",
    "express": "^5.0.0",
    "express-rate-limit": "^8.2.1",
    "helmet": "^8.0.0",
    "ioredis": "^5.9.3",
    "jsonwebtoken": "^9.0.3",
    "jszip": "^3.10.1",
    "node-pg-migrate": "^8.0.4",
    "nodemailer": "^8.0.1",
    "otpauth": "^9.5.0",
    "pg": "^8.18.0",
    "rate-limit-redis": "^4.3.1",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/bcryptjs": "^3.0.0",
    "@types/compression": "^1.7.5",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/nodemailer": "^7.0.11",
    "@types/pg": "^8.16.0",
    "@types/supertest": "^6.0.3",
    "@types/uuid": "^11.0.0",
    "eslint": "^9.17.0",
    "supertest": "^7.2.2",
    "tsx": "^4.19.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.18.0",
    "vitest": "^4.0.18"
  }
}
