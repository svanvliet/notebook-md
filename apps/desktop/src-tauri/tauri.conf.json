{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-cli/schema.json",
  "productName": "Notebook.md",
  "version": "0.1.2",
  "identifier": "io.notebookmd.desktop",
  "build": {
    "frontendDist": "../../web/dist",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "",
    "beforeDevCommand": ""
  },
  "app": {
    "windows": [
      {
        "title": "Notebook.md",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "fileAssociations": [
      {
        "ext": ["md", "mdx", "markdown"],
        "mimeType": "text/markdown",
        "description": "Markdown Document"
      }
    ],
    "macOS": {
      "entitlements": null,
      "infoPlist": {
        "LSHasLocalizedDisplayName": true,
        "CFBundleDisplayName": "Notebook.md"
      }
    },
    "resources": [
      "en.lproj/InfoPlist.strings"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/svanvliet/notebook-md/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDlDRkJCMDIwQkZBQTEyMTAKUldRUUVxcS9JTEQ3blBGOVIrbGNGZC9XSmR0YU9xSUM4blQ2OEZsSjJRN04wZndxOENoRkVIeXoK"
    }
  }
}
