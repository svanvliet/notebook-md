# Environment
NODE_ENV=development

# API
PORT=3001

# Database
DATABASE_URL=postgresql://notebookmd:localdev@localhost:5432/notebookmd

# Redis
REDIS_URL=redis://localhost:6379

# Email (Mailpit in dev)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_FROM=noreply@notebookmd.io

# OAuth (placeholder — use mock provider in dev)
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_WEBHOOK_SECRET=

# Session
SESSION_SECRET=local-dev-session-secret-change-in-prod

# Encryption (local dev key — KMS in prod)
ENCRYPTION_KEY=local-dev-encryption-key-32bytes!!
