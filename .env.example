# Environment
NODE_ENV=development

# API
PORT=3001

# Database
DATABASE_URL=postgresql://notebookmd:localdev@localhost:5432/notebookmd

# Redis
REDIS_URL=redis://localhost:6379

# Email (Mailpit in dev)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_FROM=noreply@notebookmd.io

# OAuth — GitHub OAuth App (sign-in)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# OAuth — Other providers
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# GitHub App (repo access — Phase 3)
GITHUB_APP_ID=
GITHUB_APP_CLIENT_ID=
GITHUB_APP_CLIENT_SECRET=
GITHUB_APP_PRIVATE_KEY_PATH=docker/secrets/github-app-private-key.pem
GITHUB_APP_SLUG=notebook-md
GITHUB_WEBHOOK_SECRET=

# Webhook proxy (smee.io — dev only, forwards GitHub webhooks to localhost)
# Create your own channel at https://smee.io/new
WEBHOOK_PROXY_URL=

# Session
SESSION_SECRET=local-dev-session-secret-change-in-prod

# Encryption (local dev key — KMS in prod)
ENCRYPTION_KEY=local-dev-encryption-key-32bytes!!

# Collab server
COLLAB_PORT=3002
